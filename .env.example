# LLM API 配置
IMOK_LLM_API_BASE_URL=http://localhost:8080/v1
IMOK_LLM_API_KEY=your-api-key-here
IMOK_LLM_MODEL_NAME=default

# 服务配置
IMOK_SERVER_HOST=127.0.0.1
IMOK_SERVER_PORT=18900
IMOK_SERVER_LOG_LEVEL=info

# 音频配置 (通常无需修改)
# IMOK_AUDIO_SAMPLE_RATE=16000
# IMOK_AUDIO_CHUNK_FRAMES=512
# IMOK_AUDIO_LOOPBACK_DEVICE=
# IMOK_AUDIO_MIC_DEVICE=

# ASR 配置 (留空则自动检测)
# IMOK_ASR_MODEL_SIZE=
# IMOK_ASR_COMPUTE_TYPE=
# IMOK_ASR_DEVICE=
# IMOK_ASR_BEAM_SIZE=3
