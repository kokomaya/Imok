# ===========================================================================
# LLM 后端配置 — 不要提交到版本库
# 复制为 llm_providers.yaml 并填入实际值
# ===========================================================================
#
# 支持多个 provider，通过 default_provider 选择当前使用的提供商。
# API 密钥等敏感信息应放在 .env 中，通过 ${API_TOKEN} 引用。

default_provider: "my_provider"

providers:
  my_provider:
    type: "openai_compatible"
    base_url: "https://your-api-endpoint:port"     # 替换为实际 URL
    model: "your-model-name"                        # 替换为实际模型
    api_token_env: "API_TOKEN"                      # .env 中的密钥变量名
    headers:
      useLegacyCompletionsEndpoint: "false"
      X-Tenant-ID: "default_tenant"                 # 替换为实际租户
    timeout: 60
    max_retries: 2
    stream: true                                    # 是否启用 streaming
    ssl_verify: false                               # 自签名证书设为 false

  # ── 以下为示例，可按需添加更多 provider ──

  # local_ollama:
  #   type: "openai_compatible"
  #   base_url: "http://localhost:11434/v1"
  #   model: "llama3"
  #   api_token_env: ""                             # 本地模型不需要密钥
  #   headers: {}
  #   timeout: 120
  #   max_retries: 1
  #   stream: true
  #   ssl_verify: true
